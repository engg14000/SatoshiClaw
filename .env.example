# SathoshiClaw Configuration

# Telegram Bot Token (Get from @BotFather)
TELEGRAM_BOT_TOKEN=

# WhatsApp Configuration
# Session data will be stored in 'auth_info_baileys' folder

# Logging Level (info, debug, error)
LOG_LEVEL=info

# Heartbeat Interval (in minutes) - How often to wake up and claw/meme
HEARTBEAT_INTERVAL_MINUTES=60

# Stats persistence file path
STATS_FILE=stats.json

# Optional: Discord Token
DISCORD_TOKEN=

# Enable/Disable Gateways (true/false)
ENABLE_TELEGRAM=true
ENABLE_WHATSAPP=false
ENABLE_CONSOLE=true

# Meme Intensity (0-100)
MEME_INTENSITY=100
